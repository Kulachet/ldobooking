{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the meeting room booking system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "department": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "displayName", "email", "role"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A meeting room booking record.",
      "type": "object",
      "properties": {
        "subject": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "department": { "type": "string" },
        "roomId": { "type": "string" },
        "roomName": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["approved", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["subject", "userId", "userName", "userEmail", "roomId", "startTime", "endTime", "status", "createdAt"]
    },
    "Staff": {
      "title": "Staff",
      "description": "Staff member data for profile synchronization.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "name": { "type": "string" },
        "department": { "type": "string" },
        "phone": { "type": "string" },
        "position": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["code", "name", "email"]
    },
    "Facility": {
      "title": "Facility",
      "description": "A facility available in a meeting room.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["id", "title", "description"]
    },
    "RoomDetails": {
      "title": "RoomDetails",
      "description": "Detailed information about a meeting room's facilities and gallery.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "bannerUrl": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "description": { "type": "string" },
        "facilities": { 
          "type": "array",
          "items": { "$ref": "Facility" }
        },
        "gallery": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["id", "title", "subtitle", "description", "facilities", "gallery"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile information."
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Meeting room booking records."
    },
    "/roomDetails/{roomId}": {
      "schema": "RoomDetails",
      "description": "Detailed information about a meeting room's facilities and gallery."
    },
    "/staff/{staffId}": {
      "schema": "Staff",
      "description": "Staff member data for profile synchronization."
    }
  }
}
